{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@eigencore/openfin",
  "version": "0.1.9",
  "description": "AI-powered personal financial assistant",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eigencore/openfin"
  },
  "homepage": "https://github.com/eigencore/openfin",
  "bin": {
    "openfin": "./bin/openfin"
  },
  "files": [
    "bin"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "chat": "bun run src/cli/index.ts",
    "tui": "bun run src/tui/index.ts",
    "telegram": "bun run src/telegram/index.ts",
    "build": "bun run script/build.ts",
    "typecheck": "tsc --noEmit"
  },
  "optionalDependencies": {
    "@eigencore/openfin-darwin-arm64": "0.1.9",
    "@eigencore/openfin-darwin-x64": "0.1.9",
    "@eigencore/openfin-linux-arm64": "0.1.9",
    "@eigencore/openfin-linux-x64": "0.1.9",
    "@eigencore/openfin-windows-x64": "0.1.9"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "catalog:",
    "@ai-sdk/google": "catalog:",
    "@ai-sdk/groq": "catalog:",
    "@ai-sdk/mistral": "catalog:",
    "@ai-sdk/openai": "catalog:",
    "@ai-sdk/xai": "catalog:",
    "@clack/prompts": "catalog:",
    "@openrouter/ai-sdk-provider": "catalog:",
    "@opentui/core": "catalog:",
    "@opentui/solid": "catalog:",
    "ai": "catalog:",
    "drizzle-orm": "catalog:",
    "grammy": "^1.41.1",
    "hono": "catalog:",
    "solid-js": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tsconfig/bun": "catalog:",
    "@types/bun": "catalog:",
    "drizzle-kit": "catalog:",
    "typescript": "catalog:"
  }
}
