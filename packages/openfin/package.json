{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@openfin/core",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/index.ts",
    "chat": "bun run src/cli/index.ts",
    "tui": "bun run src/tui/index.ts",
    "auth": "bun run src/cli/auth.ts",
    "auth:login": "bun run src/cli/auth.ts login",
    "auth:logout": "bun run src/cli/auth.ts logout",
    "auth:list": "bun run src/cli/auth.ts list",
    "telegram": "bun run src/telegram/index.ts",
    "build": "bun build src/index.ts --outdir dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "catalog:",
    "@ai-sdk/google": "catalog:",
    "@ai-sdk/groq": "catalog:",
    "@ai-sdk/mistral": "catalog:",
    "@ai-sdk/openai": "catalog:",
    "@ai-sdk/xai": "catalog:",
    "@clack/prompts": "catalog:",
    "@openrouter/ai-sdk-provider": "catalog:",
    "@opentui/core": "catalog:",
    "@opentui/solid": "catalog:",
    "ai": "catalog:",
    "drizzle-orm": "catalog:",
    "grammy": "^1.41.1",
    "hono": "catalog:",
    "solid-js": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tsconfig/bun": "catalog:",
    "@types/bun": "catalog:",
    "drizzle-kit": "catalog:",
    "typescript": "catalog:"
  }
}
